# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@host.railway.internal:5432/railway

# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
APP_URL=https://yourdomain.com
AGENT_VERSION=1.0.0

# ─── Security keys (generate at generate-secret.vercel.app/64) ───────────────
JWT_SECRET=
ENCRYPTION_KEY=

# ─── 2FA ─────────────────────────────────────────────────────────────────────
TOTP_ISSUER=PatchPilot

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=alerts@yourdomain.com

# ─── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx
STRIPE_PERSONAL_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxx
STRIPE_STARTER_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxx
STRIPE_GROWTH_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxx
STRIPE_SCALE_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxx

# ─── Anthropic (AI agents) ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# ─── VirusTotal (Threat Hunter hash lookups) ───────────────────────────────────
VIRUSTOTAL_API_KEY=

# ─── Firebase Cloud Messaging (Android real-time) ───────────────────────────
# Service account JSON as a single line (or use a secrets manager and inject it).
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"your-project-id","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk-...@...iam.gserviceaccount.com",...}
FIREBASE_PROJECT_ID=your-project-id
