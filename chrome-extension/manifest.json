{
  "manifest_version": 3,
  "name": "FortDefend Security",
  "version": "1.0.0",
  "description": "FortDefend device verification and security monitoring for Chromebooks",
  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "management",
    "system.cpu",
    "system.memory",
    "system.storage"
  ],
  "host_permissions": [
    "https://app.fortdefend.com/*",
    "https://fortdefend-production.up.railway.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "FortDefend Security",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
