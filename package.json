{
  "name": "patchpilot",
  "version": "1.0.0",
  "description": "PatchPilot - Windows/Chromebook Security SaaS",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "build": "cd client && npm install && npm run build",
